# Voilà Assistant - Configuration
# Copier ce fichier vers .env et ajuster les valeurs

# Fichier de session (cookies)
VOILA_SESSION_FILE=~/.secrets/voila-session.json

# Debug mode (0 ou 1)
VOILA_DEBUG=0

# Browser headless (0 pour voir le browser, 1 pour headless)
VOILA_HEADLESS=1

# Timeout pour les requêtes (secondes)
VOILA_TIMEOUT=30

# Intégration Telegram (optionnel)
TELEGRAM_ENABLED=false
